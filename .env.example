# LINE Harness 連携設定
LINE_HARNESS_API_URL=https://your-worker.workers.dev
LINE_HARNESS_ADMIN_TOKEN=your_admin_token_here
LINE_HARNESS_WEBHOOK_SECRET=your_webhook_secret_here

# LINE Messaging API（スタッフへの通知用）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
# 通知を送るスタッフのLINE User IDをカンマ区切りで設定
LINE_STAFF_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyy...

# 管理画面の認証（Basic認証）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
