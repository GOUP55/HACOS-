{
  "name": "hacos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "wrangler pages deploy",
    "preview": "npm run pages:build && wrangler pages dev",
    "db:migrate": "wrangler d1 migrations apply hacos-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply hacos-db"
  },
  "dependencies": {
    "next": "15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@line/bot-sdk": "^9.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.8",
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.3",
    "wrangler": "^4.17.0"
  }
}
